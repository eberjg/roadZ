# Server-side Mapbox token for geocoding and directions API
MAPBOX_ACCESS_TOKEN=

# Client-side Mapbox token for interactive map tiles (public token)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Force deterministic fallback routing (used in Playwright tests)
ROUTE_FORCE_FALLBACK=true

# OpenWeather API key for live current weather (optional)
OPENWEATHER_API_KEY=

# Force deterministic mock weather (used in Playwright tests)
WEATHER_FORCE_MOCK=true
